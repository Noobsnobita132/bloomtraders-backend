{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/index.html", "dest": "/index.html" },
    { "src": "/dashboard.html", "dest": "/dashboard.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
